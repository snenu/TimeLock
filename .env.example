# ===========================================
# TimeLock Environment Configuration
# Copy to .env.local and fill in values.
# ===========================================

# ----- Blockchain (Polygon Mainnet) -----
NEXT_PUBLIC_CONTRACT_ADDRESS=0x
NEXT_PUBLIC_CHAIN_ID=137
NEXT_PUBLIC_RPC_URL=https://polygon.drpc.org
# Alternative: NEXT_PUBLIC_POLYGON_MAINNET_RPC= (same as NEXT_PUBLIC_RPC_URL)
POLYGON_MAINNET_RPC=https://polygon.drpc.org

# ----- Testnet (optional) -----
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# ----- WalletConnect (https://cloud.walletconnect.com/) -----
NEXT_PUBLIC_WC_PROJECT_ID=
# Alternative: NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID= (same as NEXT_PUBLIC_WC_PROJECT_ID)

# ----- Pinata IPFS (server-only; do NOT use NEXT_PUBLIC_ for upload) -----
PINATA_API_KEY=
PINATA_SECRET_KEY=
# Alternative: PINATA_SECRET_API_KEY= (same as PINATA_SECRET_KEY)
PINATA_JWT=

# ----- Gemini AI (https://ai.google.dev/) -----
GEMINI_API_KEY=
MODEL_NAME=gemini-2.0-flash-exp

# ----- Stripe (https://dashboard.stripe.com/apikeys) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----- MongoDB (optional; not used by app currently) -----
MONGODB_URI=

# ----- Deployment (optional; for contract deploy scripts) -----
PRIVATE_KEY=
